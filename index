// ── BUILD QUESTIONS ───────────────────────────────────────────────────────────
function buildQuestions(fnId) {
  const fnQ = FN_QUESTIONS[fnId] || {};
  return CATEGORIES.map(cat => {
    const core = (CORE_QUESTIONS[cat.id] || []).map(q => ({...q, fnSpecific: false}));
    const extra = (fnQ[cat.id] || []).map(q => ({...q, fnSpecific: true}));
    return { ...cat, questions: [...core, ...extra] };
  });
}

