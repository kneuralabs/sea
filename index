      </div>
    </div>
  </div>`;

  cat.questions.forEach(q => restoreAnswer(q));
  checkGateAlert(cat);

  const nav = document.getElementById('nav-controls');
  const isLast = idx === total - 1;
  nav.innerHTML = `
    ${idx > 0 ? `<button class="nav-btn" onclick="renderCategory(${idx-1})">← Previous</button>` : ''}
    ${!isLast ? `<button class="nav-btn primary" onclick="renderCategory(${idx+1})">Next category →</button>` : ''}
    ${isLast ? `<button class="nav-btn primary" onclick="finishInterview()">Complete evaluation →</button>` : ''}
  `;

  document.getElementById('overall-note-block').style.display = isLast ? 'block' : 'none';
}

function renderQuestion(q) {
  const badge = q.type === 'yn' ? (q.gate ? 'q-gate' : 'q-rating') : q.type === 'rating' ? 'q-rating' : 'q-note';
  const badgeText = q.type === 'yn' ? (q.gate ? 'COMPLIANCE GATE' : 'YES / NO') : q.type === 'rating' ? 'RATING 1–5' : 'QUALITATIVE NOTE';
  const fnTag = q.fnSpecific ? ' <span style="font-size:9px;background:rgba(79,142,247,.15);color:var(--accent);border-radius:3px;padding:1px 5px;margin-left:4px;font-family:var(--mono)">FUNCTION-SPECIFIC</span>' : '';
  
  let input = '';
  if (q.type === 'yn') {
    const invertedNote = q.inverted ? `<div style="font-size:10px;color:var(--amber);font-family:var(--mono);margin-bottom:8px;padding:4px 8px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);border-radius:4px;display:inline-block;">⚠ NEGATIVE INDICATOR — "No" is the positive outcome</div><br>` : '';
    input = `${invertedNote}<div class="yn-group">
      <button class="yn-btn" id="yn-yes-${q.id}" onclick="answerYN('${q.id}','yes')">Yes</button>
      <button class="yn-btn" id="yn-no-${q.id}" onclick="answerYN('${q.id}','no')">No</button>
    </div>`;
  } else if (q.type === 'rating') {
    input = `<div class="rating-group">${[1,2,3,4,5].map(n=>`<button class="r-btn" id="r-${q.id}-${n}" onclick="answerRating('${q.id}',${n})">${n}</button>`).join('')}</div>
    <div class="rating-labels"><span>1 — Not evidenced</span><span>3 — Partially met</span><span>5 — Fully evidenced</span></div>`;
  } else {
    input = `<textarea class="q-textarea" id="note-${q.id}" placeholder="Add notes…" oninput="answerNote('${q.id}',this.value)"></textarea>`;
  }
  
  return `<div class="question-block">
    <div><span class="q-type-badge ${badge}">${badgeText}</span>${fnTag}</div>
    <div class="q-text">${q.text}</div>
    ${q.help ? `<div class="q-help">${q.help}</div>` : ''}
    ${input}
  </div>`;
}

function restoreAnswer(q) {
  const ans = state.answers[q.id];
  if (ans === undefined) return;
  if (q.type === 'yn') {
    const isInverted = q.inverted;
    const yesBt = document.getElementById('yn-yes-'+q.id);
    const noBt = document.getElementById('yn-no-'+q.id);
    if (yesBt && noBt) {
      if (ans === 'yes') {
        yesBt.className = 'yn-btn ' + (isInverted ? 'selected-no' : 'selected-yes');
        noBt.className = 'yn-btn';
      } else if (ans === 'no') {
        yesBt.className = 'yn-btn';
        noBt.className = 'yn-btn ' + (isInverted ? 'selected-yes' : 'selected-no');
      }
    }
  } else if (q.type === 'rating') {
    [1,2,3,4,5].forEach(n => document.getElementById(`r-${q.id}-${n}`)?.classList.toggle('selected', n===ans));
  } else {
    const ta = document.getElementById('note-'+q.id);
    if (ta) ta.value = ans || '';
  }
}

function answerYN(qId, val) {
  state.answers[qId] = val;
  const cat = state.questions[state.currentCat];
  const q = cat.questions.find(q => q.id === qId);
  const isInverted = q && q.inverted;
  const yesBt = document.getElementById('yn-yes-'+qId);
  const noBt = document.getElementById('yn-no-'+qId);
  // For inverted questions: Yes=bad(red), No=good(green). For normal: Yes=good(green), No=bad(red).
  if (val === 'yes') {
    yesBt.className = 'yn-btn ' + (isInverted ? 'selected-no' : 'selected-yes');
    noBt.className = 'yn-btn';
  } else {
    yesBt.className = 'yn-btn';
    noBt.className = 'yn-btn ' + (isInverted ? 'selected-yes' : 'selected-no');
  }
  updateCatRag(cat);
  checkGateAlert(cat);
  updateLiveHeat();
}

function answerRating(qId, val) {
  state.answers[qId] = val;
  const cat = state.questions[state.currentCat];
  [1,2,3,4,5].forEach(n => {
    const btn = document.getElementById(`r-${qId}-${n}`);
    if (btn) btn.className = 'r-btn' + (n===val ? ' selected' : '');
  });
  updateCatRag(cat);
  updateLiveHeat();
}

function answerNote(qId, val) {
  state.answers[qId] = val;
}

function updateCatRag(cat) {
  const { rag } = computeCatScore(cat);
  const el = document.getElementById('cat-rag-' + cat.id);
  if (el) el.className = 'cat-rag ' + (rag === 'neutral' ? '' : rag);
}

function checkGateAlert(cat) {
  if (!cat.gate) return;
  const alertEl = document.getElementById('gate-alert-' + cat.id);
  if (!alertEl) return;
  const tripped = cat.questions.some(q => q.gate && (
    (!q.inverted && state.answers[q.id] === 'no') ||
    (q.inverted && state.answers[q.id] === 'yes')
  ));
  alertEl.style.display = tripped ? 'block' : 'none';
}

// ── FINISH ────────────────────────────────────────────────────────────────────
function finishInterview() {
  const overallNote = document.getElementById('overall-note').value;
  const cats = state.questions;
  
  const catResults = cats.map(cat => {
    const { score, rag, gateTripped } = computeCatScore(cat);
    const noteQs = cat.questions.filter(q => q.type === 'note');
    const noteVal = noteQs.map(q => state.answers[q.id]).filter(Boolean).join(' ');
    return { ...cat, score: score !== null ? score : 0, rag, gateTripped, note: noteVal };
  });
  
  const gateTripped = catResults.some(c => c.gateTripped);
  const weightedTotal = catResults.reduce((sum, c) => sum + (c.score * c.weight / 100), 0);
  const totalScore = Math.round(weightedTotal);
  
  let signal, signalReason;
  if (gateTripped) {
    signal = 'REJECT';
    signalReason = 'One or more compliance hard gates triggered. Vendor is automatically disqualified — review gate question responses before proceeding.';
  } else if (totalScore >= 65) {
    signal = 'PROCEED';
    signalReason = `Overall weighted score: ${totalScore}/100. No gate failures. Advance to contracting.`;
  } else if (totalScore >= 40) {
    signal = 'HOLD';
    signalReason = `Overall weighted score: ${totalScore}/100. No gate failures, but score below threshold. Requires leadership review.`;
  } else {
    signal = 'REJECT';
    signalReason = `Overall weighted score: ${totalScore}/100. Score too low. Vendor does not meet minimum requirements.`;
  }
  
  const ev = {
    id: Date.now().toString(),
    fn: state.fn,
    vendorName: state.vendorName,
    contact: state.contact,
    date: state.date,
    evaluator: state.evaluator,
    companyName: state.companyName,
    contractScope: state.contractScope,
    signal,
    totalScore,
    catResults,
    overallNote,
    answers: state.answers,
  };
  
  saveEval(ev);
  renderResults(ev);
}

