<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SEA™ — Supplier Evaluation Assessment</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0b1120;
  --navy2: #111827;
  --navy3: #1a2540;
  --navy4: #243056;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
  --text: #e8eaf2;
  --muted: #7c839c;
  --accent: #4f8ef7;
  --accent2: #3a6fd4;
  --green: #22c55e;
  --green-bg: rgba(34,197,94,0.12);
  --amber: #f59e0b;
  --amber-bg: rgba(245,158,11,0.12);
  --red: #ef4444;
  --red-bg: rgba(239,68,68,0.12);
  --mono: 'DM Mono', monospace;
  --serif: 'Fraunces', serif;
  --sans: 'DM Sans', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; }
body { background: var(--navy); color: var(--text); font-family: var(--sans); font-weight: 300; min-height: 100vh; }

/* ── LAYOUT ── */
.app { display: grid; grid-template-rows: 56px 1fr; min-height: 100vh; }
header { background: var(--navy2); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 28px; gap: 16px; position: sticky; top: 0; z-index: 100; }
.logo { font-family: var(--serif); font-size: 17px; font-weight: 600; color: var(--text); letter-spacing: -.02em; }
.logo span { color: var(--accent); }
.logo sup { font-size: 9px; color: var(--muted); vertical-align: super; margin-left: 1px; }
.header-sep { flex: 1; }
.header-tag { font-family: var(--mono); font-size: 10px; color: var(--muted); background: var(--navy3); border: 1px solid var(--border); border-radius: 4px; padding: 3px 8px; }
main { padding: 32px 28px; max-width: 980px; margin: 0 auto; width: 100%; }

/* ── SCREENS ── */
.screen { display: none; animation: fadeUp .3s ease; }
.screen.active { display: block; }
@keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

/* ── HOME ── */
.home-hero { margin-bottom: 40px; }
.home-hero h1 { font-family: var(--serif); font-size: 38px; font-weight: 300; line-height: 1.15; margin-bottom: 10px; }
.home-hero h1 em { font-style: italic; color: var(--accent); }
.home-hero p { color: var(--muted); font-size: 15px; max-width: 520px; line-height: 1.6; }
.home-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px; }
.home-card { background: var(--navy2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; cursor: pointer; transition: border-color .2s, background .2s; position: relative; overflow: hidden; }
.home-card::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent) 0%, transparent 60%); opacity: 0; transition: opacity .2s; }
.home-card:hover { border-color: var(--accent2); background: var(--navy3); }
.home-card:hover::before { opacity: .04; }
.home-card:hover .card-arrow { opacity: 1; transform: translateX(0); }
.card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; }
.card-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--navy3); border: 1px solid var(--border2); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.card-arrow { color: var(--accent); font-size: 18px; opacity: 0; transform: translateX(-4px); transition: all .2s; }
.card-fn { font-size: 13px; font-weight: 400; margin-bottom: 4px; color: var(--text); }
.card-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
.card-count { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 10px; }
.past-evals { background: var(--navy2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; }
.section-label { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 14px; }
.eval-row { display: flex; align-items: center; gap: 12px; padding: 10px 12px; background: var(--navy3); border-radius: 8px; margin-bottom: 8px; cursor: pointer; transition: background .15s; border: 1px solid transparent; }
.eval-row:hover { border-color: var(--border2); background: var(--navy4); }
.eval-fn-badge { font-size: 10px; font-weight: 500; padding: 2px 8px; border-radius: 20px; background: var(--navy4); color: var(--muted); font-family: var(--mono); }
.eval-name { font-size: 13px; flex: 1; }
.eval-date { font-size: 11px; color: var(--muted); font-family: var(--mono); }
.signal-pill { font-size: 10px; font-weight: 500; padding: 3px 9px; border-radius: 20px; font-family: var(--mono); }
.pill-proceed { background: var(--green-bg); color: var(--green); }
.pill-hold { background: var(--amber-bg); color: var(--amber); }
.pill-reject { background: var(--red-bg); color: var(--red); }
.empty-state { text-align: center; padding: 24px; color: var(--muted); font-size: 13px; }

/* ── INTERVIEW ── */
.interview-header { display: flex; align-items: center; gap: 14px; margin-bottom: 28px; }
.back-btn { background: var(--navy3); border: 1px solid var(--border); color: var(--muted); border-radius: 8px; padding: 7px 14px; font-size: 13px; cursor: pointer; font-family: var(--sans); transition: all .15s; }
.back-btn:hover { color: var(--text); border-color: var(--border2); }
.interview-fn { font-family: var(--serif); font-size: 22px; font-weight: 300; }
.vendor-setup { background: var(--navy2); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 24px; }
.vendor-setup h3 { font-size: 14px; font-weight: 400; color: var(--muted); margin-bottom: 16px; font-family: var(--mono); letter-spacing: .06em; }
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.field { display: flex; flex-direction: column; gap: 6px; }
.field label { font-size: 11px; color: var(--muted); font-family: var(--mono); }
.field input, .field select { background: var(--navy3); border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px; color: var(--text); font-size: 14px; font-family: var(--sans); outline: none; transition: border-color .15s; }
.field input:focus, .field select:focus { border-color: var(--accent2); }
.field input::placeholder { color: var(--muted); }
.field select option { background: var(--navy2); }
.start-btn { background: var(--accent); color: #fff; border: none; border-radius: 8px; padding: 11px 24px; font-size: 14px; font-weight: 500; font-family: var(--sans); cursor: pointer; transition: background .15s; }
.start-btn:hover { background: var(--accent2); }
.start-btn:disabled { background: var(--navy4); color: var(--muted); cursor: not-allowed; }

/* ── PROGRESS BAR ── */
.progress-bar { background: var(--navy3); border-radius: 4px; height: 4px; margin-bottom: 24px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width .4s cubic-bezier(.4,0,.2,1); }
.progress-meta { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px; color: var(--muted); font-family: var(--mono); }

/* ── LIVE HEATMAP MINI ── */
.live-heat { display: flex; gap: 6px; margin-bottom: 24px; flex-wrap: wrap; }
.lh-cell { flex: 1; min-width: 70px; border-radius: 8px; padding: 8px; background: var(--navy3); border: 1px solid var(--border); transition: all .3s; text-align: center; }
.lh-cell.green { background: var(--green-bg); border-color: rgba(34,197,94,.3); }
.lh-cell.amber { background: var(--amber-bg); border-color: rgba(245,158,11,.3); }
.lh-cell.red { background: var(--red-bg); border-color: rgba(239,68,68,.3); }
.lh-name { font-size: 9px; color: var(--muted); font-family: var(--mono); margin-bottom: 4px; line-height: 1.3; }
.lh-score { font-family: var(--mono); font-size: 15px; font-weight: 500; color: var(--text); }
.lh-cell.green .lh-score { color: var(--green); }
.lh-cell.amber .lh-score { color: var(--amber); }
.lh-cell.red .lh-score { color: var(--red); }

/* ── CATEGORY SECTION ── */
.cat-section { background: var(--navy2); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 16px; overflow: hidden; }
.cat-header { display: flex; align-items: center; gap: 14px; padding: 16px 20px; border-bottom: 1px solid var(--border); cursor: pointer; }
.cat-num { font-family: var(--mono); font-size: 11px; color: var(--muted); width: 20px; }
.cat-title { font-size: 15px; flex: 1; }
.cat-weight { font-family: var(--mono); font-size: 10px; color: var(--muted); }
.cat-rag { width: 10px; height: 10px; border-radius: 50%; background: var(--navy4); transition: background .3s; }
.cat-rag.green { background: var(--green); }
.cat-rag.amber { background: var(--amber); }
.cat-rag.red { background: var(--red); }
.gate-tag { font-size: 9px; background: var(--red-bg); color: var(--red); border: 1px solid rgba(239,68,68,.3); padding: 2px 6px; border-radius: 4px; font-family: var(--mono); }
.cat-body { padding: 20px; }
.question-block { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
.question-block:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.q-text { font-size: 14px; line-height: 1.6; margin-bottom: 6px; }
.q-help { font-size: 12px; color: var(--muted); margin-bottom: 14px; line-height: 1.5; font-style: italic; }
.q-type-badge { display: inline-block; font-size: 9px; font-family: var(--mono); padding: 2px 6px; border-radius: 4px; margin-bottom: 8px; }
.q-gate { background: var(--red-bg); color: var(--red); border: 1px solid rgba(239,68,68,.2); }
.q-rating { background: rgba(79,142,247,.1); color: var(--accent); border: 1px solid rgba(79,142,247,.2); }
.q-note { background: var(--navy3); color: var(--muted); border: 1px solid var(--border); }

/* Yes/No toggle */
.yn-group { display: flex; gap: 8px; }
.yn-btn { padding: 9px 20px; border-radius: 8px; border: 1px solid var(--border); background: var(--navy3); color: var(--muted); font-size: 13px; font-family: var(--sans); cursor: pointer; transition: all .15s; }
.yn-btn:hover { border-color: var(--border2); color: var(--text); }
.yn-btn.selected-yes { background: var(--green-bg); border-color: rgba(34,197,94,.4); color: var(--green); }
.yn-btn.selected-no { background: var(--red-bg); border-color: rgba(239,68,68,.4); color: var(--red); }

/* Rating */
.rating-group { display: flex; gap: 8px; }
.r-btn { width: 44px; height: 44px; border-radius: 8px; border: 1px solid var(--border); background: var(--navy3); color: var(--muted); font-family: var(--mono); font-size: 16px; cursor: pointer; transition: all .15s; }
.r-btn:hover { border-color: var(--border2); color: var(--text); }
.r-btn.selected { background: var(--accent); border-color: var(--accent); color: #fff; }
.rating-labels { display: flex; justify-content: space-between; font-size: 10px; color: var(--muted); margin-top: 6px; font-family: var(--mono); }

/* Textarea */
.q-textarea { width: 100%; background: var(--navy3); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; color: var(--text); font-size: 13px; font-family: var(--sans); resize: vertical; min-height: 80px; outline: none; transition: border-color .15s; line-height: 1.5; }
.q-textarea:focus { border-color: var(--accent2); }
.q-textarea::placeholder { color: var(--muted); }

/* Nav controls */
.nav-controls { display: flex; gap: 12px; margin-top: 24px; }
.nav-btn { padding: 11px 24px; border-radius: 8px; border: 1px solid var(--border); background: var(--navy3); color: var(--text); font-size: 14px; font-family: var(--sans); cursor: pointer; transition: all .15s; }
.nav-btn:hover { border-color: var(--border2); }
.nav-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
.nav-btn.primary:hover { background: var(--accent2); }
.gate-alert { background: var(--red-bg); border: 1px solid rgba(239,68,68,.3); border-radius: 8px; padding: 12px 16px; margin-top: 12px; font-size: 13px; color: var(--red); display: none; }

/* Overall note */
.overall-note { background: var(--navy2); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
.overall-note label { font-size: 12px; color: var(--muted); font-family: var(--mono); display: block; margin-bottom: 10px; }

/* ── RESULTS ── */
.results-header { margin-bottom: 28px; }
.vendor-badge { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-bottom: 6px; }
.results-vendor { font-family: var(--serif); font-size: 30px; font-weight: 300; margin-bottom: 4px; }
.results-fn { font-size: 14px; color: var(--muted); margin-bottom: 20px; }
.signal-banner { border-radius: 12px; padding: 20px 24px; margin-bottom: 24px; display: flex; align-items: center; gap: 16px; border: 1px solid; }
.signal-banner.proceed { background: var(--green-bg); border-color: rgba(34,197,94,.3); }
.signal-banner.hold { background: var(--amber-bg); border-color: rgba(245,158,11,.3); }
.signal-banner.reject { background: var(--red-bg); border-color: rgba(239,68,68,.3); }
.signal-icon { font-size: 28px; }
.signal-label { font-family: var(--serif); font-size: 22px; font-weight: 600; }
.signal-banner.proceed .signal-label { color: var(--green); }
.signal-banner.hold .signal-label { color: var(--amber); }
.signal-banner.reject .signal-label { color: var(--red); }
.signal-reason { font-size: 13px; color: var(--muted); margin-top: 3px; }

/* Heatmap grid */
.heatmap-full { display: grid; grid-template-columns: repeat(7,1fr); gap: 10px; margin-bottom: 24px; }
.hm-cell { border-radius: 10px; padding: 14px 10px; text-align: center; border: 1px solid transparent; position: relative; }
.hm-cell.green { background: var(--green-bg); border-color: rgba(34,197,94,.25); }
.hm-cell.amber { background: var(--amber-bg); border-color: rgba(245,158,11,.25); }
.hm-cell.red { background: var(--red-bg); border-color: rgba(239,68,68,.25); }
.hm-cat { font-size: 10px; color: var(--muted); font-family: var(--mono); margin-bottom: 8px; line-height: 1.4; }
.hm-score { font-family: var(--mono); font-size: 26px; font-weight: 500; margin-bottom: 4px; }
.hm-cell.green .hm-score { color: var(--green); }
.hm-cell.amber .hm-score { color: var(--amber); }
.hm-cell.red .hm-score { color: var(--red); }
.hm-rag { font-size: 9px; font-weight: 500; font-family: var(--mono); }
.hm-cell.green .hm-rag { color: var(--green); }
.hm-cell.amber .hm-rag { color: var(--amber); }
.hm-cell.red .hm-rag { color: var(--red); }
.hm-bar-track { height: 3px; background: rgba(255,255,255,.08); border-radius: 2px; margin-top: 8px; overflow: hidden; }
.hm-bar-fill { height: 100%; border-radius: 2px; }
.hm-cell.green .hm-bar-fill { background: var(--green); }
.hm-cell.amber .hm-bar-fill { background: var(--amber); }
.hm-cell.red .hm-bar-fill { background: var(--red); }
.gate-flag { position: absolute; top: 6px; right: 6px; font-size: 8px; background: var(--red); color: #fff; padding: 1px 4px; border-radius: 3px; font-family: var(--mono); }

/* Category breakdown */
.cat-breakdown { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
.cb-row { background: var(--navy2); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; display: flex; align-items: center; gap: 14px; }
.cb-rag { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.cb-rag.green { background: var(--green); }
.cb-rag.amber { background: var(--amber); }
.cb-rag.red { background: var(--red); }
.cb-name { font-size: 13px; flex: 1; }
.cb-note { font-size: 12px; color: var(--muted); max-width: 320px; text-align: right; font-style: italic; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cb-score { font-family: var(--mono); font-size: 16px; font-weight: 500; min-width: 40px; text-align: right; }
.cb-row.green .cb-score { color: var(--green); }
.cb-row.amber .cb-score { color: var(--amber); }
.cb-row.red .cb-score { color: var(--red); }

/* Actions */
.result-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.action-btn { padding: 11px 22px; border-radius: 8px; border: 1px solid var(--border); background: var(--navy3); color: var(--text); font-size: 14px; font-family: var(--sans); cursor: pointer; transition: all .15s; }
.action-btn:hover { border-color: var(--border2); background: var(--navy4); }
.action-btn.primary { background: var(--accent); border-color: var(--accent); color: #fff; }
.action-btn.primary:hover { background: var(--accent2); }
.action-btn.contract { background: rgba(34,197,94,0.15); border-color: rgba(34,197,94,.4); color: var(--green); }
.action-btn.contract:hover { background: rgba(34,197,94,0.25); }

@media (max-width: 680px) {
  .home-grid { grid-template-columns: 1fr; }
  .field-row { grid-template-columns: 1fr; }
  .heatmap-full { grid-template-columns: repeat(4,1fr); }
  .live-heat { gap: 4px; }
  .hm-score { font-size: 20px; }
}
</style>
</head>
<body>
<div class="app">
  <header>
    <div class="logo">SEA<sup>™</sup> <span style="font-size:13px;font-weight:300;color:var(--muted);margin-left:4px;">Supplier Evaluation Assessment</span></div>
    <div class="header-sep"></div>
    <!-- Live score bar — visible only during active interview -->
    <div id="header-score-bar" style="display:none;align-items:center;gap:10px;">
      <div style="font-family:var(--mono);font-size:10px;color:var(--muted);" id="header-vendor-label"></div>
      <div style="display:flex;gap:4px;align-items:center;" id="header-cat-pills"></div>
      <div style="width:1px;height:18px;background:var(--border);margin:0 4px;"></div>
      <div style="display:flex;align-items:baseline;gap:3px;">
        <span style="font-family:var(--mono);font-size:18px;font-weight:500;" id="header-total-score">—</span>
        <span style="font-family:var(--mono);font-size:10px;color:var(--muted);">/100</span>
      </div>
      <div style="font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:4px;font-weight:500;" id="header-signal-pill"></div>
    </div>
    <div class="header-tag">VENDOR EVALUATOR v2.0</div>
  </header>
  <main>

    <!-- HOME -->
    <div class="screen active" id="screen-home">
      <div class="home-hero">
        <h1>Evaluate suppliers with<br><em>precision and structure.</em></h1>
        <p>Know exactly who you're signing before you sign. Structured vendor interviews, live scoring, and a ready-to-execute contract — all in one place.</p>
      </div>
      <div class="section-label">Select a function to begin</div>
      <div class="home-grid" id="function-grid"></div>
      <div class="past-evals">
        <div class="section-label">Past evaluations</div>
        <div id="past-list"></div>
      </div>
    </div>

    <!-- INTERVIEW -->
    <div class="screen" id="screen-interview">
      <div class="interview-header">
        <button class="back-btn" onclick="goHome()">← Back</button>
        <div class="interview-fn" id="interview-fn-title"></div>
      </div>

      <!-- Setup -->
      <div class="vendor-setup" id="setup-panel">
        <h3>Vendor details</h3>
        <div class="field-row">
          <div class="field"><label>Vendor name *</label><input type="text" id="vendor-name" placeholder="e.g. Apex HR Solutions"></div>
          <div class="field"><label>Primary contact</label><input type="text" id="vendor-contact" placeholder="Name / email"></div>
        </div>
        <div class="field-row">
          <div class="field"><label>Interview date</label><input type="date" id="interview-date"></div>
          <div class="field"><label>Evaluator name</label><input type="text" id="evaluator-name" placeholder="Your name"></div>
        </div>
        <div class="field-row">
          <div class="field"><label>Your Company Name</label><input type="text" id="company-name" placeholder="e.g. Acme Corp LLC"></div>
          <div class="field"><label>Contract Value / Scope</label><input type="text" id="contract-scope" placeholder="e.g. $24,000/year payroll services"></div>
        </div>
        <button class="start-btn" id="start-btn" onclick="startInterview()" disabled>Start Interview →</button>
      </div>

      <!-- Active interview -->
      <div id="interview-panel" style="display:none">
        <div class="progress-meta">
          <span id="progress-label">Category 1 of 7</span>
          <span id="progress-pct">0%</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
        <div class="live-heat" id="live-heat"></div>
        <div id="categories-container"></div>
        <div class="overall-note" id="overall-note-block" style="display:none">
          <label>Final evaluator note</label>
          <textarea class="q-textarea" id="overall-note" placeholder="Summarise your overall impression of this supplier…" rows="3"></textarea>
        </div>
        <div class="nav-controls" id="nav-controls"></div>
      </div>
    </div>

    <!-- RESULTS -->
    <div class="screen" id="screen-results">
      <div class="interview-header">
        <button class="back-btn" onclick="goHome()">← Home</button>
      </div>
      <div class="results-header">
        <div class="vendor-badge" id="res-badge"></div>
        <div class="results-vendor" id="res-vendor"></div>
        <div class="results-fn" id="res-fn"></div>
      </div>
      <div class="signal-banner" id="signal-banner">
        <div class="signal-icon" id="signal-icon"></div>
        <div><div class="signal-label" id="signal-label"></div><div class="signal-reason" id="signal-reason"></div></div>
      </div>
      <div class="section-label">Heatmap — layered view</div>
      <div class="heatmap-full" id="heatmap-full"></div>
      <div class="section-label">Category breakdown</div>
