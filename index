// ── LIVE HEATMAP ──────────────────────────────────────────────────────────────
function computeCatScore(cat) {
  const qs = cat.questions;
  if (!qs.length) return { score: null, rag: 'neutral', gateTripped: false };
  
  let totalWeight = 0, weightedScore = 0, gateTripped = false, answered = 0;
  
  qs.forEach(q => {
    const ans = state.answers[q.id];
    if (ans === undefined || ans === null || ans === '') return;
    answered++;
    if (q.type === 'yn') {
      // Inverted questions: "No" is the positive/good answer (e.g. "Has there been a data breach?" or "Are there lock-in clauses?")
      const positiveAnswer = q.inverted ? 'no' : 'yes';
      const val = ans === positiveAnswer ? 100 : 0;
      weightedScore += val; totalWeight += 100;
      if (q.gate && !q.inverted && ans === 'no') gateTripped = true;
      if (q.gate && q.inverted && ans === 'yes') gateTripped = true;
    } else if (q.type === 'rating') {
      const val = (ans / 5) * 100;
      weightedScore += val; totalWeight += 100;
    }
  });
  
  if (totalWeight === 0) return { score: null, rag: 'neutral', gateTripped };
  const score = Math.round(weightedScore / totalWeight * 100);
  const rag = gateTripped ? 'red' : score >= 65 ? 'green' : score >= 40 ? 'amber' : 'red';
  return { score, rag, gateTripped };
}

function renderLiveHeat() {
  const container = document.getElementById('live-heat');
  container.innerHTML = (state.questions || buildQuestions(state.fn)).map((cat, i) => {
    const { score, rag } = computeCatScore(cat);
    const ragClass = rag === 'neutral' ? '' : rag;
    return `<div class="lh-cell ${ragClass}" id="lh-${cat.id}">
      <div class="lh-name">${cat.short}</div>
      <div class="lh-score">${score !== null ? score : '—'}</div>
    </div>`;
  }).join('');
}

function updateHeaderScoreBar() {
  const bar = document.getElementById('header-score-bar');
  if (!state.questions || !state.fn) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';

  // Vendor label
  document.getElementById('header-vendor-label').textContent = state.vendorName ? state.vendorName.toUpperCase() : '';

  // Category pills
  const pills = document.getElementById('header-cat-pills');
  pills.innerHTML = state.questions.map(cat => {
    const { score, rag } = computeCatScore(cat);
    const color = rag === 'green' ? 'var(--green)' : rag === 'amber' ? 'var(--amber)' : rag === 'red' ? 'var(--red)' : 'var(--muted)';
    const bg = rag === 'green' ? 'var(--green-bg)' : rag === 'amber' ? 'var(--amber-bg)' : rag === 'red' ? 'var(--red-bg)' : 'var(--navy3)';
    return `<div title="${cat.name}" style="width:6px;height:6px;border-radius:50%;background:${color};opacity:${score !== null ? 1 : 0.3};"></div>`;
  }).join('');

  // Weighted total
  const catResults = state.questions.map(cat => {
    const { score, rag, gateTripped } = computeCatScore(cat);
    return { score: score !== null ? score : null, weight: cat.weight, rag, gateTripped };
  });
  const answered = catResults.filter(c => c.score !== null);
  let totalScore = null;
  let signal = null;
  if (answered.length > 0) {
    const weightedSum = answered.reduce((sum, c) => sum + (c.score * c.weight / 100), 0);
    const weightCovered = answered.reduce((sum, c) => sum + c.weight, 0);
    // Scale to covered weight for a live estimate
    totalScore = Math.round((weightedSum / weightCovered) * 100);
    const gateTripped = catResults.some(c => c.gateTripped);
    signal = gateTripped ? 'REJECT' : totalScore >= 70 ? 'PROCEED' : totalScore >= 50 ? 'HOLD' : 'REJECT';
  }

  const scoreEl = document.getElementById('header-total-score');
  const pillEl = document.getElementById('header-signal-pill');
  scoreEl.textContent = totalScore !== null ? totalScore : '—';

  if (signal === 'PROCEED') {
    scoreEl.style.color = 'var(--green)';
    pillEl.textContent = 'PROCEED';
    pillEl.style.cssText = 'font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:4px;font-weight:500;background:var(--green-bg);color:var(--green);border:1px solid rgba(34,197,94,.3)';
  } else if (signal === 'HOLD') {
    scoreEl.style.color = 'var(--amber)';
    pillEl.textContent = 'HOLD';
    pillEl.style.cssText = 'font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:4px;font-weight:500;background:var(--amber-bg);color:var(--amber);border:1px solid rgba(245,158,11,.3)';
  } else if (signal === 'REJECT') {
    scoreEl.style.color = 'var(--red)';
    pillEl.textContent = 'REJECT';
    pillEl.style.cssText = 'font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:4px;font-weight:500;background:var(--red-bg);color:var(--red);border:1px solid rgba(239,68,68,.3)';
  } else {
    scoreEl.style.color = 'var(--text)';
    pillEl.textContent = '';
    pillEl.style.cssText = 'font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:4px;font-weight:500;';
  }
}

function updateLiveHeat() {
  if (!state.questions) return;
  state.questions.forEach(cat => {
    const el = document.getElementById('lh-' + cat.id);
    if (!el) return;
    const { score, rag } = computeCatScore(cat);
    el.className = 'lh-cell ' + (rag === 'neutral' ? '' : rag);
    el.querySelector('.lh-score').textContent = score !== null ? score : '—';
  });
  updateHeaderScoreBar();
}

